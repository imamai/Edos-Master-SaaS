# ============================================================
# EdosPoa – Environment Variables
# Copy this file to .env.local and fill in all values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=edos.co.ke
NEXT_PUBLIC_APP_URL=https://edos.co.ke

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ───────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# For local webhook testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# STRIPE_SECRET_KEY=sk_test_...

# ── M-Pesa Daraja ────────────────────────────────────────────
# Get these from: https://developer.safaricom.co.ke
# Set MPESA_ENV=sandbox for testing, production for live
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=your-security-credential

# Shared secret embedded in the STK push CallBackURL and required by
# /api/webhooks/mpesa to accept a callback as authentic. Generate with
# `openssl rand -hex 32`. Required in every environment — the webhook
# rejects all callbacks if this is unset.
MPESA_WEBHOOK_SECRET=change-me-to-a-long-random-value

# ── eTIMS ────────────────────────────────────────────────────
# Shared secret checked by the etims-submit-invoice Edge Function so it can
# only be invoked by our own backend (etims-retry-queue and
# /api/sales/complete), not by anyone holding the public anon key. Generate
# with `openssl rand -hex 32` and set the SAME value here and as an Edge
# Function secret: `supabase secrets set ETIMS_INTERNAL_SECRET=...`
ETIMS_INTERNAL_SECRET=change-me-to-a-long-random-value

# ── Email (optional – for transactional emails) ───────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=EdosPoa <onboarding@edos.co.ke>
# Used for supplier purchase-order emails (orders@<domain>) — domain must be
# verified in Resend, same as EMAIL_FROM's domain
# RESEND_FROM_DOMAIN=edos.co.ke
